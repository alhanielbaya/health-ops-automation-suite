{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,

    /* Module settings */
    "moduleResolution": "bundler",
    "module": "ESNext",
    "noEmit": true,

    /* Environment-specific types */
    "types": ["bun-types"]
  }
}
