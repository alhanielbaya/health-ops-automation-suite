# Database .gitignore

# Database files - DO NOT COMMIT
# These should be generated fresh using init_db.py
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal

# Database backups
*.db.bak
*.sqlite.bak
*.backup

# Migration files (if using Alembic)
# Uncomment if you want to ignore migration files
# migrations/versions/*.py
# !migrations/versions/__init__.py

# Migration scripts
alembic.ini

# Data exports
*.csv
*.json
*.sql
!schema.sql

# Temporary database files
*.db-shm
*.db-wal

# Local database configurations
config.local.py
config.local.yml

# SQLite temporary files
*.db-journal
*.db-wal
*.db-shm
AGENTS.MD